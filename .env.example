# School Information System — Environment Variables

# JWT Secret (REQUIRED — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Server Port
PORT=5000

# Client URL (for CORS) — comma-separated for multiple origins
# Local: http://localhost:5173
# Production: https://schoolhub-mu.vercel.app
CLIENT_URL=http://localhost:5173,https://schoolhub-mu.vercel.app

# Anthropic API Key (optional — enables AI features)
ANTHROPIC_API_KEY=

# ─── Supabase (optional — enables cloud database) ────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── Sentry (optional — enables error monitoring) ─────────────────
VITE_SENTRY_DSN=
SENTRY_DSN=

# ─── Database Mode ───────────────────────────────────────────────
# If SUPABASE_URL is set, uses Supabase PostgreSQL
# Otherwise, uses local SQLite (server/school.db)
